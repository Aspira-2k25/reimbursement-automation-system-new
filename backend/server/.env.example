# ============================================
# Reimbursement System - Environment Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000

# PostgreSQL Database (Local Development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reimburse
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# PostgreSQL Connection URLs (Production)
# Use one of these formats for production:
# DB_POSTGRES_URL=postgresql://user:password@host:port/database?sslmode=require
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require
# POSTGRES_URL=postgresql://user:password@host:port/database?sslmode=require

# MongoDB
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# JWT Configuration
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_character_or_longer_random_secret_here_minimum_sixty_four_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_SECRET_KEY=your_secret_key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password_here

# Redis (for token blacklist in serverless)
# REDIS_URL=redis://username:password@host:port

# Security
# BCRYPT_ROUNDS=12
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
